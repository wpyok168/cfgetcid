// ====================== 你提供的百度OCR服务类 ======================
class BaiduOcrService {
  constructor() {
    this.apiKey = 'OFClXkRRS9TRRTDvnKMk4TS1';
    this.secretKey = 'cyWM6fnvKn5eeLAR6WBGZwYkU2OufuOJ';

    this.tokenUrl = 'https://aip.baidubce.com/oauth/2.0/token';
    this.ocrUrl = 'https://aip.baidubce.com/rest/2.0/ocr/v1/general_basic';
    this.tokenFile = 'baidu_ocr_token.json';
    this.tokenExpiryDays = 20;
  }

  async getAccessToken() {
    const maxRetries = 3;
    let retryDelay = 1;

    for (let retry = 0; retry < maxRetries; retry++) {
      try {
        if (fsSync.existsSync(this.tokenFile)) {
          const content = await fs.readFile(this.tokenFile, 'utf8');
          const tokenData = JSON.parse(content);
          const now = Date.now() / 1000;

          if (now < tokenData.expire_time) {
            const remain = (tokenData.expire_time - now) / 3600;
            console.log(`使用缓存token，剩余 ${remain.toFixed(1)} 小时`);
            return tokenData.access_token;
          } else {
            console.log('token 已过期，删除缓存');
            await fs.unlink(this.tokenFile);
          }
        }
      } catch (e) {
        console.error('读取token缓存失败', e);
        try {
          await fs.unlink(this.tokenFile);
        } catch {}
      }

      try {
        console.log(`重新获取token ${retry + 1}/${maxRetries}`);
        const res = await axios.get(this.tokenUrl, {
          params: {
            grant_type: 'client_credentials',
            client_id: this.apiKey,
            client_secret: this.secretKey
          },
          timeout: 10000
        });

        const data = res.data;
        if (data.access_token) {
          const tokenData = {
            access_token: data.access_token,
            expire_time: Date.now() / 1000 + this.tokenExpiryDays * 86400
          };
          await fs.writeFile(this.tokenFile, JSON.stringify(tokenData, null, 2), 'utf8');
          console.log('获取token成功');
          return data.access_token;
        } else {
          console.error('获取token失败', data);
        }
      } catch (e) {
        console.error('请求token异常', e.message);
      }

      if (retry < maxRetries - 1) {
        await this.sleep(retryDelay * 1000);
        retryDelay *= 2;
      }
    }

    console.error('token 获取失败，已达最大重试');
    return null;
  }

  async recognizeBuffer(buffer) {
    const token = await this.getAccessToken();
    if (!token) return null;

    try {
      const base64 = buffer.toString('base64');

      const maxRetries = 3;
      let retryDelay = 2;

      for (let retry = 0; retry < maxRetries; retry++) {
        try {
          const start = Date.now();
          const res = await axios.post(
            this.ocrUrl,
            new URLSearchParams({ image: base64 }),
            {
              params: { access_token: token },
              headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
              timeout: 60000
            }
          );
          const cost = (Date.now() - start) / 1000;

          const isHtml = /<html|<!doctype html/i.test(res.data);
          if (isHtml) {
            console.error('返回HTML页面，视为504');
            res.status = 504;
          }

          if (res.status === 200) {
            const result = res.data;
            if (result.words_result) {
              console.log(`OCR 成功，${result.words_result.length} 行，耗时 ${cost}s`);
              const fullText = this.extractText(result);
              console.log('识别文本：', fullText);

              const numInfo = this.extractSpecialNumbers(fullText);
              console.log('提取数字：', numInfo);

              return { fullText, ...numInfo, raw: result };
            } else if (result.error_code === 110) {
              console.error('token 失效，清除缓存');
              await fs.unlink(this.tokenFile).catch(() => {});
              return this.recognizeBuffer(buffer);
            } else {
              console.error('OCR 返回错误', result);
            }
          }
        } catch (e) {
          console.error(`OCR 请求异常 ${retry + 1}/${maxRetries}`, e.message);
        }

        if (retry < maxRetries - 1) {
          await this.sleep(retryDelay * 1000);
          retryDelay *= 2;
        }
      }
    } catch (e) {
      console.error('处理图片失败', e);
    }

    console.error('OCR 失败，已达最大重试');
    return null;
  }

  extractText(ocrResult) {
    if (!ocrResult?.words_result) return '';
    return ocrResult.words_result
      .map(item => (item.words || '').replace(/\s+/g, ''))
      .join('');
  }

  extractSpecialNumbers(text) {
    const s = text.replace(/\s+/g, '');
    const match63 = s.match(/\d{63}/);
    if (match63) {
      return { number: match63[0], length: '63', fullText: text };
    }
    return { number: null, length: null, fullText: text };
  }

  sleep(ms) {
    return new Promise(r => setTimeout(r, ms));
  }
}

const app = express();
app.use(cors());
app.use(express.json({ limit: '50mb' }));
app.use(express.urlencoded({ extended: true }));

// ====================== 配置 ======================
const LOG_PASSWORD = process.env.LOG_PASSWORD || '123456';
const PORT = process.env.PORT || 9567;
const KV_DIR = path.join(__dirname, 'kv_logs');
const BATCH_SIZE = 20;
const BATCH_FLUSH_SECONDS = 300;
const MAX_BATCH_READ = 50;
const PAGE_SIZE = 20;
const TIMEZONE = 8;

// 实例化OCR
const ocrService = new BaiduOcrService();

const upload = multer({ storage: multer.memoryStorage(), limits: { fileSize: 20 * 1024 * 1024 } });

// ====================== 日志批处理 ======================
let logBatch = [];
let lastFlushTime = Date.now();
let flushing = false;

(async () => {
  try { await fs.access(KV_DIR); } catch { await fs.mkdir(KV_DIR); }
})();

// ====================== 工具函数 ======================
function isAuth(req) {
  const cookies = cookie.parse(req.headers.cookie || '');
  return cookies.log_token === LOG_PASSWORD;
}

function eI(t) {
  const e = t instanceof ArrayBuffer ? new Uint8Array(t) : new TextEncoder().encode(t);
  let n = '';
  for (const o of e) n += String.fromCharCode(o);
  return btoa(n).replace(/\+/g, '-').replace(/\//g, '_').replace(/=+$/, '');
}

let tI = null;
async function yT() {
  if (!tI) {
    tI = await crypto.subtle.generateKey({ name: 'ECDSA', namedCurve: 'P-256' }, true, ['sign', 'verify']);
  }
  return tI;
}

async function c1(t, e) {
  const key = await yT();
  const jwk = await crypto.subtle.exportKey('jwk', key.publicKey);
  const header = eI(JSON.stringify({ alg: 'ES256', typ: 'dpop+jwt', jwk }));
  const payload = eI(JSON.stringify({
    htu: t, htm: e, jti: crypto.randomUUID(), iat: Math.floor(Date.now() / 1000)
  }));
  const unsigned = header + '.' + payload;
  const signature = await crypto.subtle.sign(
    { name: 'ECDSA', hash: 'SHA-256' },
    key.privateKey,
    new TextEncoder().encode(unsigned)
  );
  return unsigned + '.' + eI(signature);
}

function GenerateSessionId() {
  return 'app_' + Math.random().toString(36).slice(2, 15);
}

async function safeParse(resp) {
  const text = await resp.text();
  try { return JSON.parse(text); } catch { return { raw: text }; }
}

function getFormatTime(offset = 8) {
  const now = new Date();
  const utc = now.getTime() + now.getTimezoneOffset() * 60000;
  const tz = new Date(utc + 3600000 * offset);
  return tz.toISOString().replace('T', ' ').slice(0, 19);
}

// ====================== IID 提取规则（修正：过滤无关数字，优先7位组→6位组） ======================
function extractIIDs(text) {
  const results = [];

  let filteredText = text.replace(/\b(800|400)\d{1,7}\b/g, '');
  filteredText = filteredText.replace(/\b\d{1,5}\b|\b\d{8,9}\b/g, '');

  const pattern54 = /\b(?:\d{6}\s+){8}\d{6}\b/g;
  const pattern63 = /\b(?:\d{7}\s+){8}\d{7}\b/g;

  const m54 = filteredText.match(pattern54) || [];
  const m63 = filteredText.match(pattern63) || [];

  for (const s of m63) {
    const c = s.replace(/\s+/g, '');
    if (c.length === 63) results.push(c);
  }

  for (const s of m54) {
    const c = s.replace(/\s+/g, '');
    if (c.length === 54) results.push(c);
  }

  const nums = filteredText.match(/\d{54,63}/g) || [];
  for (const n of nums) {
    if (n.length === 63) {
      results.push(n);
    }
  }
  for (const n of nums) {
    if (n.length === 54) {
      results.push(n);
    }
  }

  const allDigits = filteredText.replace(/\D/g, '');
  if (allDigits.length >= 63) {
    results.push(allDigits.slice(0, 63));
  } else if (allDigits.length >= 54) {
    results.push(allDigits.slice(0, 54));
  }

  return [...new Set(results)];
}

// ====================== KV 存储 ======================
async function flushBatch() {
  if (flushing || logBatch.length === 0) return;
  flushing = true;
  try {
    const key = 'batch_' + Date.now() + '_' + crypto.randomUUID();
    const file = path.join(KV_DIR, key + '.json');
    await fs.writeFile(file, JSON.stringify(logBatch), 'utf8');
    logBatch = [];
    lastFlushTime = Date.now();
  } finally {
    flushing = false;
  }
}

function needFlush() {
  if (logBatch.length >= BATCH_SIZE) return true;
  return (Date.now() - lastFlushTime) / 1000 > BATCH_FLUSH_SECONDS;
}

async function getAllLogs() {
  try {
    const files = await fs.readdir(KV_DIR);
    const all = [];
    for (const f of files.slice(-MAX_BATCH_READ)) {
      try {
        const txt = await fs.readFile(path.join(KV_DIR, f), 'utf8');
        const arr = JSON.parse(txt);
        if (Array.isArray(arr)) all.push(...arr);
      } catch { }
    }
    return all.sort((a, b) => (b.time || '').localeCompare(a.time || ''));
  } catch { return []; }
}

async function deleteLogById(targetId) {
  if (!targetId) return false;
  const files = await fs.readdir(KV_DIR);
  for (const f of files) {
    const file = path.join(KV_DIR, f);
    try {
      const txt = await fs.readFile(file, 'utf8');
      const arr = JSON.parse(txt);
      const filtered = arr.filter(x => x.id !== targetId);
      if (filtered.length !== arr.length) {
        if (filtered.length === 0) await fs.unlink(file);
        else await fs.writeFile(file, JSON.stringify(filtered), 'utf8');
        return true;
      }
    } catch { }
  }
  return false;
}

async function clearAllLogs() {
  const files = await fs.readdir(KV_DIR);
  await Promise.all(files.map(f => fs.unlink(path.join(KV_DIR, f))));
}

