app.listen(PORT, () => {
  console.log(`✅ 服务已启动：http://127.0.0.1:${PORT}`);
  console.log(`🔑 日志后台密码：${LOG_PASSWORD}`);
  console.log(`📷 已使用你提供的新版百度OCR类`);
  console.log(`📷 新增：图片OCR识别 → 自动获取CID`);
});
